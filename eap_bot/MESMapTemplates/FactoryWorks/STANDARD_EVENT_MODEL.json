  "Payloads": [
    {
      "PayloadName": "LotStartPayload",
      "Fields": [
        "EquipmentID",
        "LotID",
        "RecipeName",
        "RecipeVersion",
        "CarrierID",
        "PortID",
        "OperatorID",
        "EventTime"
      ]
    },
    {
      "PayloadName": "LotEndPayload",
      "Fields": [
        "EquipmentID",
        "LotID",
        "RecipeName",
        "EventTime"
      ]
    },
    {
      "PayloadName": "WaferPayload",
      "Fields": [
        "EquipmentID",
        "LotID",
        "WaferID",
        "SlotNumber",
        "EventTime"
      ]
    },
    {
      "PayloadName": "AlarmPayload",
      "Fields": [
        "EquipmentID",
        "AlarmID",
        "AlarmText",
        "AlarmSeverity",
        "EventTime"
      ]
    },
    {
      "PayloadName": "StateChangePayload",
      "Fields": [
        "EquipmentID",
        "EquipmentState",
        "EventTime"
      ]
    }
  ],
  "Transactions": [
    {
      "Transaction": "TXN_LOT_START",
      "Method": "StartLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_LOT_END",
      "Method": "EndLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_WAFER_START",
      "Method": "StartWafer",
      "Direction": "EquipmentToMES",
      "AckRequired": false,
      "Timeout": 10,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_WAFER_END",
      "Method": "EndWafer",
      "Direction": "EquipmentToMES",
      "AckRequired": false,
      "Timeout": 10,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_ALARM_SET",
      "Method": "CreateAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_ALARM_CLEAR",
      "Method": "ClearAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_STATE_CHANGE",
      "Method": "UpdateEquipmentState",
      "Direction": "EquipmentToMES",
      "AckRequired": false,
      "Timeout": 10,
      "RetryCount": 1
    }
  ],
  "ValidationRules": [
    {
      "Field": "LotID",
      "Rule": "Required"
    },
    {
      "Field": "RecipeName",
      "Rule": "Required"
    },
    {
      "Field": "EquipmentID",
      "Rule": "Required"
    },
    {
      "Field": "EventTime",
      "Rule": "UTCDateTime"
    },
    {
      "Field": "EquipmentState",
      "Rule": "AllowedValues:Idle,Running,Paused,Error,Maintenance"
    }
  ],
  "AutoMapping": {
    "Enabled": true,
    "Strategy": "DynamicVIDMapping",
    "CanonicalModel": true,
    "UnknownVIDHandling": "IgnoreAndLog",
    "RequiredFieldValidation": true
  },
  "Logging": {
    "Enabled": true,
    "AuditEnabled": true,
    "StorePayload": true,
    "StoreRawSECSMessage": true,
    "LogLevel": "Information"
  }
}