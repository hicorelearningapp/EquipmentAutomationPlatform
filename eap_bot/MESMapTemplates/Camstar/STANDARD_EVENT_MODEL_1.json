{
  "TemplateName": "STANDARD_EVENT_MODEL_1",
  "Version": "1.0",
  "Description": "Camstar template variant 1. Provides basic process events and alarm handling.",
  "Events": [
    {
      "EventName": "LotStart",
      "EventType": "Process",
      "Transaction": "TXN_LOT_START",
      "Payload": "LotStartPayload",
      "Enabled": true,
      "EquipmentField": ""
    },
    {
      "EventName": "LotEnd",
      "EventType": "Process",
      "Transaction": "TXN_LOT_END",
      "Payload": "LotEndPayload",
      "Enabled": true,
      "EquipmentField": ""
    },
    {
      "EventName": "AlarmSet",
      "EventType": "Alarm",
      "Transaction": "TXN_ALARM_SET",
      "Payload": "AlarmPayload",
      "Enabled": true,
      "EquipmentField": ""
    },
    {
      "EventName": "AlarmClear",
      "EventType": "Alarm",
      "Transaction": "TXN_ALARM_CLEAR",
      "Payload": "AlarmPayload",
      "Enabled": true,
      "EquipmentField": ""
    },
    {
      "EventName": "TrackIn",
      "EventType": "Process",
      "Transaction": "TXN_TRACK_IN",
      "Enabled": true,
      "EquipmentField": ""
    },
    {
      "EventName": "TrackOut",
      "EventType": "Process",
      "Transaction": "TXN_TRACK_OUT",
      "Enabled": true,
      "EquipmentField": ""
    }
  ],
  "Alarms": [
    {
      "AlarmType": "EquipmentAlarm",
      "Severity": "Critical",
      "Transaction": "TXN_ALARM_SET",
      "Enabled": true,
      "EquipmentField": ""
    },
    {
      "AlarmType": "ProcessAlarm",
      "Severity": "Warning",
      "Transaction": "TXN_ALARM_SET",
      "Enabled": true,
      "EquipmentField": ""
    }
  ],
  "Variables": [
    {
      "MESField": "EquipmentID",
      "Type": "String",
      "Required": true,
      "Description": "",
      "Enabled": true,
      "EquipmentField": ""
    },
    {
      "MESField": "LotID",
      "Type": "String",
      "Required": true,
      "Description": "",
      "Enabled": true,
      "EquipmentField": ""
    },
    {
      "MESField": "ContainerName",
      "Type": "String",
      "Required": false,
      "Description": "",
      "Enabled": true,
      "EquipmentField": ""
    },
    {
      "MESField": "RecipeName",
      "Type": "String",
      "Required": true,
      "Description": "",
      "Enabled": true,
      "EquipmentField": ""
    },
    {
      "MESField": "OperationName",
      "Type": "String",
      "Required": false,
      "Description": "",
      "Enabled": true,
      "EquipmentField": ""
    },
    {
      "MESField": "EventTime",
      "Type": "DateTime",
      "Required": true,
      "Description": "",
      "Enabled": true,
      "EquipmentField": ""
    }
  ],
  "Payloads": [
    {
      "PayloadName": "LotStartPayload",
      "Fields": [
        "EquipmentID",
        "LotID",
        "ContainerName",
        "RecipeName",
        "OperationName",
        "EventTime"
      ]
    },
    {
      "PayloadName": "LotEndPayload",
      "Fields": [
        "EquipmentID",
        "LotID",
        "RecipeName",
        "OperationName",
        "EventTime"
      ]
    },
    {
      "PayloadName": "AlarmPayload",
      "Fields": [
        "EquipmentID",
        "AlarmID",
        "AlarmText",
        "AlarmSeverity",
        "EventTime"
      ]
    }
  ],
  "Transactions": [
    {
      "Transaction": "TXN_LOT_START",
      "Method": "MoveIn",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_LOT_END",
      "Method": "MoveOut",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_ALARM_SET",
      "Method": "CreateAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_ALARM_CLEAR",
      "Method": "ClearAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    }
  ],
  "ValidationRules": [
    {
      "Field": "LotID",
      "Rule": "Required"
    },
    {
      "Field": "RecipeName",
      "Rule": "Required"
    },
    {
      "Field": "EquipmentID",
      "Rule": "Required"
    },
    {
      "Field": "EventTime",
      "Rule": "UTCDateTime"
    }
  ]
}