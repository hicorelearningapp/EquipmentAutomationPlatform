  "Transactions": [
    {
      "Transaction": "TXN_LOT_START",
      "Method": "MoveIn",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3,
      "MESDescription": ""
    },
    {
      "Transaction": "TXN_LOT_END",
      "Method": "MoveOut",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3,
      "MESDescription": ""
    },
    {
      "Transaction": "TXN_CONTAINER_MOVE",
      "Method": "ContainerMove",
      "Direction": "EquipmentToMES",
      "AckRequired": false,
      "Timeout": 15,
      "RetryCount": 2,
      "MESDescription": ""
    },
    {
      "Transaction": "TXN_DC_START",
      "Method": "StartDataCollection",
      "Direction": "EquipmentToMES",
      "AckRequired": false,
      "Timeout": 10,
      "RetryCount": 1,
      "MESDescription": ""
    },
    {
      "Transaction": "TXN_DC_END",
      "Method": "CompleteDataCollection",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 20,
      "RetryCount": 2,
      "MESDescription": ""
    },
    {
      "Transaction": "TXN_ALARM_SET",
      "Method": "CreateAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2,
      "MESDescription": ""
    },
    {
      "Transaction": "TXN_ALARM_CLEAR",
      "Method": "ClearAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2,
      "MESDescription": ""
    }
  ],
  "ValidationRules": [
    {
      "Field": "LotID",
      "Rule": "Required"
    },
    {
      "Field": "RecipeName",
      "Rule": "Required"
    },
    {
      "Field": "EquipmentID",
      "Rule": "Required"
    },
    {
      "Field": "EventTime",
      "Rule": "UTCDateTime"
    },
    {
      "Field": "ContainerType",
      "Rule": "AllowedValues:Cassette,FOUP,Boat,Tray"
    }
  ],
  "Logging": {
    "Enabled": true,
    "AuditEnabled": true,
    "StorePayload": true,
    "StoreRawSECSMessage": true,
    "LogLevel": "Information"
  }
