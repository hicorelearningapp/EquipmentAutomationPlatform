    {
      "Field": "LotID",
      "Rule": "Required"
    },
    {
      "Field": "RecipeName",
      "Rule": "Required"
    },
    {
      "Field": "EquipmentID",
      "Rule": "Required"
    },
    {
      "Field": "EventTime",
      "Rule": "UTCDateTime"
    },
    {
      "Field": "WorkOrderID",
      "Rule": "NonEmptyIfPresent"
    }
  ],
