  "Transactions": [
    {
      "Transaction": "TXN_LOT_START",
      "Method": "StartLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_LOT_END",
      "Method": "EndLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_MATERIAL_IN",
      "Method": "MaterialIn",
      "Direction": "EquipmentToMES",
      "AckRequired": false,
      "Timeout": 10,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_MATERIAL_OUT",
      "Method": "MaterialOut",
      "Direction": "EquipmentToMES",
      "AckRequired": false,
      "Timeout": 10,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_PARAM_DATA",
      "Method": "ReportParametricData",
      "Direction": "EquipmentToMES",
      "AckRequired": false,
      "Timeout": 20,
      "RetryCount": 1
    },
    {
      "Transaction": "TXN_ALARM_SET",
      "Method": "CreateAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_ALARM_CLEAR",
      "Method": "ClearAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_SCHEDULER_REQUEST",
      "Method": "RequestSchedule",
      "Direction": "MESToEquipment",
      "AckRequired": true,
      "Timeout": 60,
      "RetryCount": 1
    }
  ],
