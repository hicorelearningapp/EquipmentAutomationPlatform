  "Payloads": [
    {
      "PayloadName": "LotStartPayload",
      "Fields": [
        "EquipmentID",
        "LotID",
        "RecipeName",
        "CarrierID",
        "PortID",
        "EventTime"
      ]
    },
    {
      "PayloadName": "LotEndPayload",
      "Fields": [
        "EquipmentID",
        "LotID",
        "RecipeName",
        "EventTime"
      ]
    },
    {
      "PayloadName": "AlarmPayload",
      "Fields": [
        "EquipmentID",
        "AlarmID",
        "AlarmText",
        "AlarmSeverity",
        "EventTime"
      ]
    },
    {
      "PayloadName": "CustomPayload",
      "Fields": [
        "EquipmentID",
        "LotID",
        "CustomField1",
        "CustomField2",
        "CustomField3",
        "EventTime"
      ]
    }
  ],
  "Transactions": [
    {
      "Transaction": "TXN_LOT_START",
      "Method": "StartLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_LOT_END",
      "Method": "EndLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_ALARM_SET",
      "Method": "CreateAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_ALARM_CLEAR",
      "Method": "ClearAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_CUSTOM_EVENT",
      "Method": "HandleCustomEvent",
      "Direction": "EquipmentToMES",
      "AckRequired": false,
      "Timeout": 20,
      "RetryCount": 1
    }
  ],
  "ValidationRules": [
    {
      "Field": "LotID",
      "Rule": "Required"
    },
    {
      "Field": "RecipeName",
      "Rule": "Required"
    },
    {
      "Field": "EquipmentID",
      "Rule": "Required"
    },
    {
      "Field": "EventTime",
      "Rule": "UTCDateTime"
    }
  ],
  "Logging": {
    "Enabled": true,
    "AuditEnabled": true,
    "StorePayload": true,
    "StoreRawSECSMessage": true,
    "LogLevel": "Information"
  }
