{
  "MESFamily": "FAB300",
  "TemplateName": "STANDARD_EVENT_MODEL",
  "Version": "1.0",
  "Description": "Generic MES integration template independent of equipment",
  "Events": [
    {
      "EventName": "LotStart",
      "EventType": "Process",
      "Transaction": "TXN_LOT_START",
      "Payload": "LotStartPayload",
      "Enabled": true
    },
    {
      "EventName": "LotEnd",
      "EventType": "Process",
      "Transaction": "TXN_LOT_END",
      "Payload": "LotEndPayload",
      "Enabled": true
    },
    {
      "EventName": "AlarmSet",
      "EventType": "Alarm",
      "Transaction": "TXN_ALARM_SET",
      "Payload": "AlarmPayload",
      "Enabled": true
    },
    {
      "EventName": "AlarmClear",
      "EventType": "Alarm",
      "Transaction": "TXN_ALARM_CLEAR",
      "Payload": "AlarmPayload",
      "Enabled": true
    },
    {
      "EventName": "TrackIn",
      "EventType": "Process",
      "Transaction": "TXN_TRACK_IN",
      "Enabled": true
    },
    {
      "EventName": "TrackOut",
      "EventType": "Process",
      "Transaction": "TXN_TRACK_OUT",
      "Enabled": true
    }
  ],
  "Alarms": [
    {
      "AlarmType": "EquipmentAlarm",
      "Severity": "Critical",
      "Transaction": "TXN_ALARM_SET",
      "Enabled": true
    },
    {
      "AlarmType": "ProcessAlarm",
      "Severity": "Warning",
      "Transaction": "TXN_PROCESS_WARNING",
      "Enabled": true
    }
  ],
  "Variables": [
    {
      "MESField": "EquipmentID",
      "Type": "String",
      "Required": true,
      "Description": "",
      "Enabled": true
    },
    {
      "MESField": "LotID",
      "Type": "String",
      "Required": true,
      "Description": "",
      "Enabled": true
    },
    {
      "MESField": "RecipeName",
      "Type": "String",
      "Required": true,
      "Description": "",
      "Enabled": true
    },
    {
      "MESField": "CarrierID",
      "Type": "String",
      "Required": false,
      "Description": "",
      "Enabled": true
    },
    {
      "MESField": "PortID",
      "Type": "String",
      "Required": false,
      "Description": "",
      "Enabled": true
    },
    {
      "MESField": "SlotNumber",
      "Type": "Integer",
      "Required": false,
      "Description": "",
      "Enabled": true
    },
    {
      "MESField": "AlarmID",
      "Type": "Integer",
      "Required": false,
      "Description": "",
      "Enabled": true
    },
    {
      "MESField": "AlarmText",
      "Type": "String",
      "Required": false,
      "Description": "",
      "Enabled": true
    },
    {
      "MESField": "AlarmSeverity",
      "Type": "String",
      "Required": false,
      "Description": "",
      "Enabled": true
    },
    {
      "MESField": "EventTime",
      "Type": "DateTime",
      "Required": true,
      "Description": "",
      "Enabled": true
    }
  ],
  "Payloads": [
    {
      "PayloadName": "LotStartPayload",
      "Fields": [
        "EquipmentID",
        "LotID",
        "RecipeName",
        "CarrierID",
        "PortID",
        "EventTime"
      ]
    },
    {
      "PayloadName": "LotEndPayload",
      "Fields": [
        "EquipmentID",
        "LotID",
        "RecipeName",
        "EventTime"
      ]
    },
    {
      "PayloadName": "AlarmPayload",
      "Fields": [
        "EquipmentID",
        "AlarmID",
        "AlarmText",
        "AlarmSeverity",
        "EventTime"
      ]
    }
  ],
  "Transactions": [
    {
      "Transaction": "TXN_LOT_START",
      "Method": "StartLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_LOT_END",
      "Method": "EndLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_ALARM_SET",
      "Method": "CreateAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_ALARM_CLEAR",
      "Method": "ClearAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    }
  ],
  "ValidationRules": [
    {
      "Field": "LotID",
      "Rule": "Required"
    },
    {
      "Field": "RecipeName",
      "Rule": "Required"
    },
    {
      "Field": "EquipmentID",
      "Rule": "Required"
    },
    {
      "Field": "EventTime",
      "Rule": "UTCDateTime"
    }
  ],
  "Logging": {
    "Enabled": true,
    "AuditEnabled": true,
    "StorePayload": true,
    "StoreRawSECSMessage": true,
    "LogLevel": "Information"
  }
}