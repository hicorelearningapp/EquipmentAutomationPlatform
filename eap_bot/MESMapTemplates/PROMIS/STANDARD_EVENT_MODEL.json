      ]
    }
  ],
  "Transactions": [
    {
      "Transaction": "TXN_LOT_START",
      "Method": "StartLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 45,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_LOT_END",
      "Method": "EndLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 45,
      "RetryCount": 3
    },
    {
      "Transaction": "TXN_LOT_SPLIT",
      "Method": "SplitLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_LOT_MERGE",
      "Method": "MergeLot",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 30,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_ALARM_SET",
      "Method": "CreateAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_ALARM_CLEAR",
      "Method": "ClearAlarm",
      "Direction": "EquipmentToMES",
      "AckRequired": true,
      "Timeout": 15,
      "RetryCount": 2
    },
    {
      "Transaction": "TXN_RECIPE_DOWNLOAD",
      "Method": "DownloadRecipe",
      "Direction": "MESToEquipment",
      "AckRequired": true,
      "Timeout": 60,
      "RetryCount": 1
    }
  ],
  "ValidationRules": [
    {
      "Field": "LotID",
      "Rule": "Required"
    },
    {
      "Field": "RecipeName",
      "Rule": "Required"
    },
    {
      "Field": "EquipmentID",
      "Rule": "Required"
    },
    {
      "Field": "EventTime",
      "Rule": "UTCDateTime"
    },
    {
      "Field": "RouteID",
      "Rule": "NonEmptyIfPresent"
    }
  ],
  "Logging": {
    "Enabled": true,
    "AuditEnabled": true,
    "StorePayload": true,
    "StoreRawSECSMessage": true,
    "LogLevel": "Information"
  }
